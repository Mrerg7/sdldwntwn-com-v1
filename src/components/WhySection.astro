---
import { getCollection } from 'astro:content';

const valueProps = (await getCollection('value-props')).sort((a, b) => a.data.order - b.data.order);
---

<section class="max-w-5xl mx-auto px-6 pt-16 pb-12" id="why">
  <div class="max-w-2xl">
    <div class="uppercase tracking-[2px] text-xs font-semibold text-amber-700 mb-3">THE OPPORTUNITY</div>
    <h2 class="text-5xl tracking-tighter font-semibold heading-serif">
      Own the go-to domain<br />for Downtown Scottsdale.
    </h2>
    <p class="mt-5 text-lg text-slate-600">
      sdldwntwn.com is short, instantly recognizable, and perfectly aligned with one of Scottsdale's most iconic and
      valuable districts — Old Town / Downtown Scottsdale. It delivers immediate local authority and strong branding
      potential for anyone building in real estate, events, tourism, dining, arts, or lifestyle in the heart of the city.
    </p>
  </div>

  <div class="mt-12 grid md:grid-cols-3 gap-5">
    {
      valueProps.map(({ data }) => (
        <div class="value-card bg-white border border-slate-200 rounded-3xl p-7">
          <div class="text-amber-700 text-xs tracking-widest font-semibold mb-3">{data.label}</div>
          <div class="font-semibold text-xl tracking-tight">{data.title}</div>
          <p class="mt-3 text-sm text-slate-600">{data.description}</p>
        </div>
      ))
    }
  </div>
</section>
