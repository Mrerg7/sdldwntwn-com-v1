---
import { getCollection } from 'astro:content';

const facts = (await getCollection('facts')).sort((a, b) => a.data.order - b.data.order);
---

<section class="max-w-5xl mx-auto px-6 py-16" id="facts">
  <div class="max-w-2xl mb-10">
    <div class="uppercase tracking-[2px] text-xs font-semibold text-amber-700 mb-3">THE MARKET</div>
    <h2 class="text-4xl tracking-tighter font-semibold">
      Downtown Scottsdale (Old Town) is the vibrant, walkable heart of the city.
    </h2>
    <p class="mt-4 text-slate-600">
      Commonly known as Old Town Scottsdale, this historic district blends authentic Old West heritage with modern
      luxury. It serves as the cultural, commercial, and tourism centerpiece of Scottsdale — a condensed,
      pedestrian-friendly area filled with world-class art, dining, shopping, and nightlife.
    </p>
  </div>

  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
    {
      facts.map(({ data }) => (
        <div class="value-card bg-white border border-slate-200 rounded-3xl p-7">
          <div class="text-amber-700 text-xs tracking-widest font-semibold mb-2">{data.label}</div>
          <div class="font-semibold text-lg">{data.title}</div>
          <p class="mt-3 text-sm text-slate-600">{data.description}</p>
        </div>
      ))
    }
  </div>

  <p class="mt-8 text-xs text-slate-500 max-w-3xl">
    Sources: City of Scottsdale, Experience Scottsdale, Old Town Scottsdale official resources, and 2024–2025 tourism
    studies. Old Town Scottsdale is the primary historic and cultural downtown district of the city.
  </p>
</section>
