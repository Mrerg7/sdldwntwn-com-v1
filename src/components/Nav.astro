---
import { ACQUISITION_MAILTO, SITE } from '../config/site';
---

<nav class="bg-white/95 backdrop-blur-md border-b border-slate-200 sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex justify-between items-center h-20">
      <div class="flex items-center gap-x-3">
        <div class="w-9 h-9 bg-slate-900 rounded-2xl flex items-center justify-center">
          <span class="text-white font-bold text-xl tracking-tighter">SDL</span>
        </div>
        <div class="font-semibold text-xl tracking-tighter text-slate-900">
          sdldwntwn<span class="text-amber-700">.</span>com
        </div>
      </div>

      <div class="hidden md:flex items-center gap-x-8 text-sm font-medium">
        <a href="#why" class="nav-link text-slate-600 hover:text-slate-900">Why This Domain</a>
        <a href="#perfect-for" class="nav-link text-slate-600 hover:text-slate-900">Perfect For</a>
        <a href="#facts" class="nav-link text-slate-600 hover:text-slate-900">Downtown Scottsdale</a>
        <a href="#acquire" class="nav-link text-slate-600 hover:text-slate-900">Acquire</a>
      </div>

      <div class="flex items-center gap-x-3">
        <a
          href="https://sdl.contact"
          target="_blank"
          rel="noopener noreferrer"
          class="hidden md:inline text-xs px-4 py-2 border border-slate-300 hover:bg-slate-100 rounded-3xl font-medium text-slate-600 transition-colors"
        >
          SDL Portfolio
        </a>
        <a
          href={ACQUISITION_MAILTO}
          class="px-6 py-2.5 bg-slate-900 hover:bg-black text-white text-sm font-semibold rounded-3xl transition-all active:scale-[0.985]"
        >
          Make an Offer
        </a>
      </div>
    </div>
  </div>
</nav>
