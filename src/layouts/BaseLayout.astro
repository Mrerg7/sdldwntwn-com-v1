---
import '../styles/global.css';
import { SITE, OG_IMAGE, ACQUISITION_MAILTO, PUBLISHED_DATE, DOMAIN_PRICE } from '../config/site';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title = SITE.title,
  description = SITE.description,
  ogImage = OG_IMAGE,
  noindex = false,
} = Astro.props;

const pathname = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const canonicalURL = new URL(pathname, SITE.url);

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${SITE.url}#website`,
      url: SITE.url,
      name: SITE.name,
      description,
      inLanguage: 'en-US',
    },
    {
      '@type': 'WebPage',
      '@id': `${SITE.url}#webpage`,
      url: SITE.url,
      name: title,
      description,
      isPartOf: { '@id': `${SITE.url}#website` },
      datePublished: PUBLISHED_DATE,
      dateModified: PUBLISHED_DATE,
      inLanguage: 'en-US',
    },
    {
      '@type': 'Product',
      '@id': `${SITE.url}#product`,
      name: 'sdldwntwn.com Premium Domain Name',
      description:
        'The definitive premium .com domain for Downtown Scottsdale and Old Town Scottsdale. Available for acquisition.',
      url: SITE.url,
      image: OG_IMAGE,
      category: 'Premium Domain Name',
      brand: {
        '@type': 'Brand',
        name: 'sdldwntwn.com',
      },
      offers: {
        '@type': 'Offer',
        url: ACQUISITION_MAILTO,
        availability: 'https://schema.org/InStock',
        price: DOMAIN_PRICE.price,
        priceCurrency: DOMAIN_PRICE.currency,
        priceSpecification: {
          '@type': 'PriceSpecification',
          price: DOMAIN_PRICE.price,
          minPrice: DOMAIN_PRICE.minPrice,
          maxPrice: DOMAIN_PRICE.maxPrice,
          priceCurrency: DOMAIN_PRICE.currency,
        },
        seller: {
          '@type': 'Organization',
          name: SITE.name,
          email: SITE.email,
        },
      },
      review: [
        {
          '@type': 'Review',
          author: { '@type': 'Organization', name: 'SDL Domains' },
          datePublished: PUBLISHED_DATE,
          reviewBody:
            'A short, brandable .com domain ideally suited for Downtown Scottsdale and Old Town real estate, tourism, events, and local lifestyle brands.',
          reviewRating: {
            '@type': 'Rating',
            ratingValue: 5,
            bestRating: 5,
          },
        },
      ],
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: 5,
        bestRating: 5,
        reviewCount: 1,
        ratingCount: 1,
      },
    },
    {
      '@type': 'Organization',
      '@id': `${SITE.url}#organization`,
      name: SITE.name,
      url: SITE.url,
      email: SITE.email,
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Scottsdale',
        addressRegion: 'AZ',
        addressCountry: 'US',
      },
    },
    {
      '@type': 'Place',
      '@id': `${SITE.url}#place`,
      name: 'Downtown Scottsdale (Old Town)',
      description:
        'The historic, walkable cultural and commercial heart of Scottsdale, Arizona — home to galleries, dining, nightlife, and luxury living.',
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Scottsdale',
        addressRegion: 'AZ',
        addressCountry: 'US',
      },
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="sdldwntwn.com, downtown Scottsdale domain for sale, Old Town Scottsdale domain, Scottsdale real estate domain, Scottsdale events domain, Scottsdale tourism domain, premium Scottsdale downtown domain"
    />
    <meta name="author" content="SDL Domains" />
    <meta name="robots" content={noindex ? 'noindex' : 'index, follow, max-image-preview:large'} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="sdldwntwn.com — Premium Domain for Downtown Scottsdale & Old Town" />
    <meta property="og:locale" content={SITE.locale} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="sdldwntwn.com — Premium Domain for Downtown Scottsdale & Old Town" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {SITE.googleSiteVerification && (
      <meta name="google-site-verification" content={SITE.googleSiteVerification} />
    )}
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <slot />
  </body>
</html>
